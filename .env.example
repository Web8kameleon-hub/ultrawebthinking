# JONA Production Environment Variables
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to Git - only .env.example

# ==================== APPLICATION ====================
APP_NAME=JONA - Intelligent Neural Operating Architecture
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# ==================== API CONFIG ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30
API_RATE_LIMIT=1000

# ==================== DATABASE ====================
# PostgreSQL Connection
DATABASE_URL=postgresql://jona:CHANGE_ME@postgres:5432/jona_db
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ==================== CACHE & SESSION ====================
# Redis Connection
REDIS_URL=redis://CHANGE_ME@redis:6379/0
REDIS_POOL_SIZE=10
REDIS_TTL=86400

# ==================== DOCUMENT DB ====================
# MongoDB Connection
MONGO_URL=mongodb://CHANGE_ME@mongodb:27017
MONGO_DB=jona_prod

# ==================== SECURITY ====================
# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# CORS Configuration
CORS_ORIGINS=["*"]
ALLOWED_HOSTS=["localhost", "127.0.0.1", "jona.yourdomain.com"]

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=

# ==================== MONITORING ====================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15

# ==================== FILE UPLOAD ====================
MAX_UPLOAD_SIZE=52428800

# ==================== EXTERNAL SERVICES ====================
# Groq API (if using)
GROQ_API_KEY=CHANGE_ME_TO_YOUR_GROQ_API_KEY
GROQ_MODEL=mixtral-8x7b-32768

# Other LLM Providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ==================== BILLING & INFRASTRUCTURE ====================
# Hetzner Configuration (Admin only - not exposed to clients)
HETZNER_TOKEN=CHANGE_ME_TO_YOUR_HETZNER_TOKEN
HETZNER_REGION=nbg1
HETZNER_MONTHLY_COST=8.99

# ==================== EMAIL (Optional) ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ==================== SLACK (Optional) ====================
SLACK_WEBHOOK_URL=

# ==================== STRIPE (Optional) ====================
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
